# ─── FUAI Environment Variables ─────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME
#DATABASE_URL="postgresql://postgres:Ajeem@123@localhost:5432/fuai"
DATABASE_URL="postgresql://postgres:Ajeem%40123@localhost:5432/fuai"
# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="fuai_super_secret_2026_random_key_12345"

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
# If omitted, app runs in demo mode with mock responses
OPENAI_API_KEY=""

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── (Optional) Google OAuth ───────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
